# ============================================================
# MoviePilot V2 环境变量配置
# 复制为 .env 并填入实际值:
#   cp .env.example .env
# ============================================================

# TMDB API Key（必填 - 用于影片元数据刮削）
# 申请地址: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# 登录密码（必填 - 首次登录用）
SUPERUSER_PASSWORD=changeme123

# qBittorrent 密码（如果启用下载器）
QB_PASSWORD=adminadmin

# Jackett API Key（如果启用索引器）
# 登录 Jackett Web UI 后查看
JACKETT_API_KEY=your_jackett_api_key_here
